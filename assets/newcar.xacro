<?xml version="1.0"?>
<robot name="mentorpi_ackermann" xmlns:xacro="http://ros.org/wiki/xacro">
  <material name="chassis_blue">
    <color rgba="0.16 0.42 0.78 1.0"/>
  </material>
  <material name="matte_black">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>
  <material name="sensor_gray">
    <color rgba="0.7 0.72 0.75 1.0"/>
  </material>
  <material name="wheel_marker">
    <color rgba="1.0 0.15 0.05 1.0"/>
  </material>

  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 -0.014"/>
      <mass value="0.92"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.018" iyz="0" izz="0.018"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.012"/>
      <geometry>
        <box size="0.213 0.145 0.045"/>
      </geometry>
      <material name="chassis_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.012"/>
      <geometry>
        <box size="0.213 0.145 0.045"/>
      </geometry>
    </collision>
  </link>

  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.0335" rpy="0 0 0"/>
  </joint>

  <link name="left_hinge">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
    </inertial>
  </link>
  <joint name="base_to_left_hinge" type="revolute">
    <parent link="base_link"/>
    <child link="left_hinge"/>
    <origin xyz="0.0725 0.0665 -0.0335" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="25" lower="-0.506145" upper="0.506145" velocity="10"/>
  </joint>

  <link name="right_hinge">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000005" ixy="0" ixz="0" iyy="0.000005" iyz="0" izz="0.000005"/>
    </inertial>
  </link>
  <joint name="base_to_right_hinge" type="revolute">
    <parent link="base_link"/>
    <child link="right_hinge"/>
    <origin xyz="0.0725 -0.0665 -0.0335" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="25" lower="-0.506145" upper="0.506145" velocity="10"/>
  </joint>

  <link name="left_front_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00003"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.026 0 0"/>
      <geometry>
        <box size="0.012 0.028 0.006"/>
      </geometry>
      <material name="wheel_marker"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
    </collision>
  </link>
  <joint name="left_hinge_to_left_front_wheel" type="continuous">
    <parent link="left_hinge"/>
    <child link="left_front_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_front_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00003"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.026 0 0"/>
      <geometry>
        <box size="0.012 0.028 0.006"/>
      </geometry>
      <material name="wheel_marker"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
    </collision>
  </link>
  <joint name="right_hinge_to_right_front_wheel" type="continuous">
    <parent link="right_hinge"/>
    <child link="right_front_wheel"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="left_back_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00003"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.026 0 0"/>
      <geometry>
        <box size="0.012 0.028 0.006"/>
      </geometry>
      <material name="wheel_marker"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
    </collision>
  </link>
  <joint name="base_to_left_back_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="left_back_wheel"/>
    <origin xyz="-0.0725 0.0665 -0.0335" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_back_wheel">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00003" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00003"/>
    </inertial>
    <visual>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
      <material name="matte_black"/>
    </visual>
    <visual>
      <origin xyz="0.026 0 0"/>
      <geometry>
        <box size="0.012 0.028 0.006"/>
      </geometry>
      <material name="wheel_marker"/>
    </visual>
    <collision>
      <origin rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="0.0335" length="0.024"/>
      </geometry>
    </collision>
  </link>
  <joint name="base_to_right_back_wheel" type="continuous">
    <parent link="base_link"/>
    <child link="right_back_wheel"/>
    <origin xyz="-0.0725 -0.0665 -0.0335" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="depth_cam">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.04 0.02 0.02"/>
      </geometry>
      <material name="sensor_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.04 0.02 0.02"/>
      </geometry>
    </collision>
  </link>
  <joint name="cam_Joint" type="fixed">
    <origin xyz="0.064015 -0.00013463 0.051155" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="depth_cam"/>
  </joint>

  <link name="lidar_frame">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.006"/>
      <geometry>
        <cylinder radius="0.022" length="0.012"/>
      </geometry>
      <material name="sensor_gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.006"/>
      <geometry>
        <cylinder radius="0.022" length="0.012"/>
      </geometry>
    </collision>
  </link>
  <joint name="lidar_Joint" type="fixed">
    <origin xyz="-0.0096019 -0.00008533 0.092501" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_frame"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.005"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>
  <joint name="imu_joint" type="fixed">
    <origin xyz="0.0 0.0 0.045" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>
</robot>
